{
  "name": "infogen-trace-infrastructure",
  "version": "1.0.0",
  "description": "OpenTelemetry-compatible trace capture for agent execution observability",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test '**/*.test.ts'",
    "test:coverage": "c8 --include=src/**/*.ts --all node --import tsx --test '**/*.test.ts'"
  },
  "keywords": ["opentelemetry", "tracing", "observability", "agent"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
